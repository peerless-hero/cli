<% if(dts.notes.length) { -%>
/**
<% dts.notes.forEach(note => { -%>
 * <%- note %>
 *
<% }) -%>
 */
<% } -%>
<% if(dts.type==='any') { -%>
export declare interface <%- dts.name %> {
<% dts.properties.forEach(property => { -%>
<% if(property.notes.length) { -%>
  /**
<% property.notes.forEach(note => { -%>
   * <%- note %>
   *
<% }) -%>
   */
<% } -%>
  <%- property.name -%><% if(!property.required){ %>?<% } %>: <%- property.type %>
<% }) -%>
}
<% } else { -%>
export declare type <%- dts.name %> = <%- dts.type %>
<% } -%>
