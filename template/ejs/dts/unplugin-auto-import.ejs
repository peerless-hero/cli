declare global {
<% importsMap[pkgName].forEach(fun => { -%>
  const <%- fun %>: typeof import('<%- pkgName %>')['<%- fun %>']
<% }) -%>
}
// for vue template auto import
import { UnwrapRef } from 'vue'
declare module 'vue' {
  interface ComponentCustomProperties {
<% importsMap[pkgName].forEach(fun => { -%>
    readonly <%- fun %>: UnwrapRef<typeof import('<%- pkgName %>')['<%- fun %>']>
<% }) -%>
  }
}
