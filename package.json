{
  "name": "@peerless_hero/cli",
  "type": "module",
  "version": "0.4.0",
  "packageManager": "yarn@1.22.22",
  "author": "peerless_hero <peerless_hero@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/peerless-hero/clir#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peerless-hero/cli.git"
  },
  "bugs": "https://github.com/peerless-hero/cli/issues",
  "keywords": [
    "peerless_hero",
    "cli"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.mts"
      ]
    }
  },
  "bin": {
    "cli": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/commands/cli.ts",
    "dev:api": "tsx src/commands/api.ts",
    "dev:changelog": "tsx src/commands/changelog.ts",
    "dev:request": "tsx src/commands/request.ts",
    "dev:type": "tsx src/commands/type.ts",
    "dev:version": "tsx src/commands/version.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "release": "bumpp",
    "bump:prerelease": "changelogen --release --bump --prerelease --push",
    "bump:patch": "changelogen --patch --bump --release --push",
    "bump:minor": "changelogen --minor --bump --release --push",
    "bump:major": "changelogen --major --bump --release --push",
    "start": "node bin/cli.mjs",
    "start:api": "node bin/api.mjs",
    "start:changelog": "node bin/changelog.mjs",
    "start:request": "node bin/request.mjs",
    "start:type": "node bin/type.mjs",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "tsdown": "^0.22.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@antfu/ni": "^0.21.12",
    "@antfu/utils": "^0.7.7",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.7",
    "@types/semver": "^7.5.8",
    "bumpp": "^9.4.0",
    "changelogen": "^0.6.2",
    "consola": "3.2.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "eslint": "^10.6.0",
    "lint-staged": "^15.2.2",
    "openapi-types": "^12.1.3",
    "rimraf": "^5.0.5",
    "semver": "7.6.3",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.9"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "volta": {
    "node": "22.23.1",
    "yarn": "1.22.22"
  }
}
